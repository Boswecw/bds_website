{
  "version": "0.2.1",
  "seed": "stateforge-v0.1-fixed-seed",
  "defaults": {
    "maxDepth": 30,
    "maxStates": 200000
  },
  "actions": [
    "start_execution"
  ],
  "nodes": {
    "pipeline": {
      "initial": "PLANNING",
      "approvalState": "APPROVED",
      "terminal": [
        "FAILED",
        "RELEASED"
      ],
      "failureTransitions": [
        "PLANNING"
      ],
      "transitions": {
        "PLANNING:start_execution": "PLANNING"
      }
    },
    "authority": {
      "actors": [
        "Human",
        "SMITH",
        "Service"
      ],
      "rings": [
        "R0",
        "R1",
        "R2"
      ],
      "requirements": {
        "start_execution": {
          "actor": "SMITH",
          "ring": "R1"
        }
      }
    },
    "circuit_breaker": {
      "initial": "OK",
      "statuses": [
        "OK",
        "DEGRADED",
        "DOWN"
      ],
      "criticalActions": [
        "start_execution"
      ]
    }
  },
  "evidence_chain": {
    "maxLen": 3,
    "hashAlg": "sha256",
    "allowSealEmpty": false,
    "actions": [
      "ev_append_invalid_prev",
      "ev_append_valid",
      "ev_fork",
      "ev_mutate_after_seal",
      "ev_seal"
    ]
  }
}
